# Copy to .env and edit. Not committed.

# Gateway -> model server
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=not-needed

# vLLM backend only: the single model it loads at launch, plus GPU tuning.
# Ollama ignores these -- the gateway manages Ollama models via models.toml.
VLLM_MODEL=Qwen/Qwen2.5-Coder-1.5B-Instruct
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.90
