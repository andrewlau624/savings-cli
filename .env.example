# ===== Gateway =====
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_LOG_LEVEL=info

# Redis (caching layer)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# LLM (vLLM endpoint on your homelab device)
LLM_BASE_URL=http://vllm-homelab.tailnet-name.ts.net:8000/v1
LLM_MODEL=savings-coder
LLM_API_KEY=not-needed-over-tailscale

# Budget / token limits
BUDGET_DAILY_LIMIT=1000000
BUDGET_USER_LIMIT=100000

# Ledger
LEDGER_DB_PATH=/data/ledger.db
LEDGER_HMAC_KEY=

# Tailscale
TAILSCALE_AUTH_KEY=

# Observability
OTEL_SERVICE_NAME=savings-gateway
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# Discord alerting
DISCORD_WEBHOOK_URL=